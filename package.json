{
	"name": "arbitrum-testnode-workspace",
	"version": "0.2.2",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"build": "pnpm -r --if-present build",
		"dev": "pnpm --filter arbitrum-testnode dev",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc -b",
		"validate": "pnpm lint && pnpm build && pnpm typecheck && pnpm test:run"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^25.3.4",
		"esbuild": "^0.27.3",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
