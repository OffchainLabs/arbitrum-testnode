{
	"name": "@arbitrum/testnode-core",
	"version": "0.2.2",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./*.js": {
			"types": "./src/*.ts",
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@arbitrum/chain-sdk": "0.26.0",
		"viem": "^2.47.5"
	}
}
